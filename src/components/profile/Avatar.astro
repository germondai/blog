// Copyright (C) 2025 germondai - https://github.com/germondai

interface Props {
  src?: string
  name: string
  size?: number
  glow?: boolean
  class?: string
}

const { src, name, size = 96, glow = true, class: className = '' } = Astro.props

const initials = name
  .split(' ')
  .map((w) => w[0])
  .join('')
  .toUpperCase()
  .slice(0, 2)
---

<div
  class={`relative inline-block rounded-full ${className}`}
  style={`width:${size}px;height:${size}px`}
>
  {
    glow && (
      <>
        <div
          aria-hidden="true"
          class="absolute rounded-full"
          style={`inset:-${Math.round(size * 0.35)}px;opacity:0.55;background:radial-gradient(circle,color-mix(in srgb,var(--accent) 60%,transparent) 0%,transparent 60%);filter:blur(${Math.round(size * 0.28)}px)`}
        />
        <div
          aria-hidden="true"
          class="absolute rounded-full"
          style={`inset:-${Math.round(size * 0.08)}px;opacity:0.35;background:radial-gradient(circle,var(--accent) 0%,transparent 70%);filter:blur(${Math.round(size * 0.12)}px)`}
        />
      </>
    )
  }

  {
    src ? (
      <img
        src={src}
        alt={`${name} avatar`}
        width={size}
        height={size}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="relative block rounded-full object-cover"
        style={`width:${size}px;height:${size}px`}
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
      />
    ) : null
  }

  <div
    class={`${src ? 'hidden' : 'flex'} relative items-center justify-center rounded-full font-semibold text-white`}
    style={`width:${size}px;height:${size}px;background:var(--accent);font-size:${Math.round(size * 0.33)}px`}
    aria-label={`${name} avatar`}
  >
    {initials}
  </div>
</div>
