---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Copyright (C) 2025 germondai - https://github.com/germondai

interface Props {
  title: string
  description: string
  canonicalUrl: string
  siteName?: string
  ogImage?: string
  ogImageAlt?: string
  ogType?: 'website' | 'article'
  twitterHandle?: string
  publishDate?: Date
  updatedDate?: Date
  tags?: string[]
  lang: string
  alternateUrls?: Record<string, string>
}

const {
  title,
  description,
  canonicalUrl,
  siteName,
  ogImage,
  ogImageAlt,
  ogType = 'website',
  twitterHandle,
  publishDate,
  updatedDate,
  tags,
  lang,
  alternateUrls,
} = Astro.props

const imageAlt = ogImageAlt ?? title
---

<meta name="description" content={description} />
{tags?.length && <meta name="keywords" content={tags.join(', ')} />}

<link rel="canonical" href={canonicalUrl} />

{alternateUrls && Object.entries(alternateUrls).map(([locale, url]) => (
  <link rel="alternate" hreflang={locale} href={url} />
))}
<link rel="alternate" hreflang="x-default" href={canonicalUrl} />

<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:locale" content={lang.replace('-', '_')} />
{siteName && <meta property="og:site_name" content={siteName} />}
{ogImage && (
  <>
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
  </>
)}
{publishDate && <meta property="article:published_time" content={publishDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
{tags?.map((tag) => <meta property="article:tag" content={tag} />)}
{alternateUrls && Object.keys(alternateUrls).map((locale) => (
  <meta property="og:locale:alternate" content={locale.replace('-', '_')} />
))}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{twitterHandle && <meta name="twitter:creator" content={twitterHandle} />}
{twitterHandle && <meta name="twitter:site" content={twitterHandle} />}
{ogImage && (
  <>
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />
  </>
)}
