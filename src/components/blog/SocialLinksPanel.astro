import { t } from '@/i18n'

interface Props {
  shareUrl?: string
  shareTitle?: string
  lang?: string
}

const { shareUrl, shareTitle, lang = 'en' } = Astro.props
const i18n = t(lang)

const shareLinks = shareUrl
  ? [
      {
        label: 'X / Twitter',
        slug: 'twitter',
        href: `https://x.com/intent/tweet?text=${encodeURIComponent(`${shareTitle ?? ''}\n\n${shareUrl}`)}`,
      },
      {
        label: 'LinkedIn',
        slug: 'linkedin',
        href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`,
      },
      {
        label: 'Bluesky',
        slug: 'bluesky',
        href: `https://bsky.app/intent/compose?text=${encodeURIComponent(`${shareTitle ?? ''}\n\n${shareUrl}`)}`,
      },
    ]
  : []
---

{shareLinks.length > 0 && (
  <div class="mt-3">
    <p class="mb-2.5 text-xs font-semibold uppercase tracking-widest text-white/25">{i18n.blog.share}</p>
    <div class="flex flex-wrap gap-1.5">
      {shareLinks.map(({ label, slug, href }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          title={label}
          aria-label={label}
          class="flex h-7 w-7 items-center justify-center rounded-lg text-white/30 transition-all hover:scale-105 hover:text-white/65"
          style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07)"
        >
          <img
            src={`https://icons.germondai.com/icons?i=${slug}:mono:fff:full:transparent`}
            alt={label}
            width={13}
            height={13}
            loading="lazy"
            decoding="async"
            style="opacity:0.5"
          />
        </a>
      ))}
      <button
        type="button"
        id="lb-copy-link"
        data-url={shareUrl}
        title={i18n.blog.copyLink}
        aria-label={i18n.blog.copyLink}
        class="flex h-7 w-7 items-center justify-center rounded-lg text-white/30 transition-all hover:scale-105 hover:text-white/65"
        style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07)"
      >
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4.5 7.5l3-3M7 2H10V5M10 2L6.5 5.5M5 10H2V7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
)}

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('lb-copy-link')
    if (!btn) return
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url
      if (!url) return
      try {
        await navigator.clipboard.writeText(url)
        btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'
        btn.style.color = 'rgb(134,239,172)'
        setTimeout(() => {
          btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4.5 7.5l3-3M7 2H10V5M10 2L6.5 5.5M5 10H2V7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>'
          btn.style.color = ''
        }, 2000)
      } catch {}
    })
  })
</script>
