import BaseLayout from '@/components/layout/BaseLayout.astro'
import GlassCard from '@/components/layout/GlassCard.astro'
import Button from '@/components/ui/Button.astro'
import { t } from '@/i18n'
import { resolveConfig } from '@/lib/config'
import config from '../../blog.config'

const resolved = resolveConfig(config)
const defaultLang = resolved.blog.defaultLanguage
const i18n = t(defaultLang)
---

<BaseLayout
  title={i18n.notFound.title}
  description={i18n.notFound.message}
  lang={defaultLang}
>
  <div class="flex flex-1 items-center justify-center px-4 py-20">
    <GlassCard class="w-full max-w-md p-8 text-center">
      <p class="mb-2 text-7xl font-bold" style="color:var(--accent)">404</p>
      <h1 class="mb-3 text-2xl font-semibold text-white">{i18n.notFound.title}</h1>
      <p class="mb-8 text-white/55">{i18n.notFound.message}</p>
      <div class="flex flex-wrap justify-center gap-3">
        <Button href="/" variant="accent">{i18n.notFound.home}</Button>
        <Button href="/blog" variant="outline">{i18n.notFound.viewBlog}</Button>
      </div>
    </GlassCard>
  </div>
</BaseLayout>
