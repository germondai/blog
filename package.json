{
  "name": "@germondai/blog",
  "version": "1.0.0",
  "description": "Self-hostable personal blog - a FOSS, Astro 6 SSG with i18n, MDX, and single-file config",
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "germondai",
    "url": "https://github.com/germondai"
  },
  "homepage": "https://github.com/germondai/blog#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/germondai/blog.git"
  },
  "bugs": {
    "url": "https://github.com/germondai/blog/issues"
  },
  "keywords": [
    "blog",
    "personal-blog",
    "astro",
    "astro-blog",
    "self-hosted",
    "self-hostable",
    "ssg",
    "static-site",
    "mdx",
    "i18n",
    "multilingual",
    "typescript",
    "tailwindcss",
    "foss",
    "open-source",
    "pwa",
    "docker"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "type": "module",
  "scripts": {
    "setup": "bun scripts/setup.ts",
    "icons": "bun scripts/generate-icons.ts",
    "font": "bun scripts/generate-font.ts",
    "manifest": "bun scripts/generate-manifest.ts",
    "og": "bun scripts/generate-og.ts",
    "predev": "bun scripts/setup.ts",
    "dev": "astro dev",
    "prebuild": "bun scripts/generate-icons.ts && bun scripts/generate-font.ts && bun scripts/generate-manifest.ts && bun scripts/generate-og.ts",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format ./src",
    "format:write": "biome format --write ./src",
    "check": "biome check ./src",
    "check:write": "biome check --write ./src",
    "astro:check": "astro check",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "motion": "^12.40.0",
    "nanostores": "^1.3.0",
    "rehype-external-links": "^3.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.4.16",
    "bun-types": "^1.3.14",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "sharp"
  ],
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ]
}
