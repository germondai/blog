# version control
.git
.gitignore

# deps (reinstalled inside the image)
node_modules

# build output (rebuilt inside the image)
dist
.astro

# local env - never bake secrets into the image
.env
.env.*
!.env.example

# dev / test artefacts
coverage
*.tsbuildinfo

# editor & OS noise
.DS_Store
*.pem
.vscode
.idea

# CI / deploy configs not needed at runtime
.github
netlify.toml
vercel.json

# docs
README.md
CHANGELOG.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
AGENTS.md
PLAN.md
CODEOWNERS
